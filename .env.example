# ── Application ───────────────────────────────────────────────────
APP_NAME=Smart Visit Avignon
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=smartvisit

# ── Neo4j ─────────────────────────────────────────────────────────
# Must match NEO4J_AUTH in docker-compose.yml (format: user/password)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Apache Spark ──────────────────────────────────────────────────
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077

# ── Routing (OSRM) ────────────────────────────────────────────────
OSRM_API_URL=http://router.project-osrm.org/route/v1/driving/

# ── Observability ─────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
